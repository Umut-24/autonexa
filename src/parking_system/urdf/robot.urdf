<?xml version="1.0"?>
<!--
  Static fallback URDF. The authoritative source is robot.urdf.xacro plus
  ~/.autonexa/robot_dimensions.yaml, rendered by scripts/build_urdf.py at
  launch time and live-edited by the mobile bridge. This file is kept in
  sync with the xacro defaults so any tool that still reads robot.urdf
  directly gets the corrected geometry.
-->
<robot name="parking_robot">
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.27 0.2 0.1"/>
      </geometry>
      <material name="base_color">
        <color rgba="0.2 0.2 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.27 0.2 0.1"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
    </inertial>
  </link>

  <link name="laser_link">
    <visual>
      <geometry>
        <cylinder radius="0.035" length="0.05"/>
      </geometry>
      <material name="laser_color">
        <color rgba="1.0 0.0 0.0 1.0"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_link"/>
    <origin xyz="0.01 0.0 0.07" rpy="0 0 3.14159"/>
  </joint>

  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.03 0.025 0.02"/>
      </geometry>
      <material name="camera_color">
        <color rgba="0.0 0.0 0.0 1.0"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.1 0.0 0.05" rpy="0 0 0"/>
  </joint>
</robot>
