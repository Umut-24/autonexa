<!--
  Ackermann-aware NavigateToPose behavior tree.

  Derived from Nav2's navigate_to_pose_w_replanning_and_recovery.xml with
  one chassis-specific change: the <Spin> recovery action is removed.
  A front-steer rear-drive Ackermann robot cannot rotate in place, so
  Spin is guaranteed to fail and only burns a recovery slot. BackUp,
  Wait, and ClearCostmap remain — all useful for un-wedging from
  inflated corners or stale obstacle observations.

  BackUp distance shortened to 0.20 m (from default 0.30 m) for the
  2x2 m parking testbed; full 0.30 m would over-shoot the workspace.
-->
<root BTCPP_format="4" main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <!--
      Outer retry budget pulled from 6 → 4. Six retries on a 2x2 m
      testbed produced very long stuck-then-recovering sequences; 4
      gives the BT enough chances to clear stale obstacles and back
      up without leaving the operator staring at a frozen chassis.
    -->
    <RecoveryNode number_of_retries="4" name="NavigateRecovery">
      <PipelineSequence name="NavigateWithReplanning">
        <ControllerSelector selected_controller="{selected_controller}" default_controller="FollowPath" topic_name="controller_selector"/>
        <PlannerSelector selected_planner="{selected_planner}" default_planner="GridBased" topic_name="planner_selector"/>
        <!--
          Replan at 2 Hz (was 1 Hz). When collision_monitor or RPP's own
          collision check zeros velocity briefly, the BT had to wait a full
          second before recomputing — long enough that the user saw the
          robot freeze and assumed the chain was wedged. 2 Hz halves that
          stall while staying well within the planner's 2.0 s timeout budget.
        -->
        <RateController hz="2.0">
          <RecoveryNode number_of_retries="1" name="ComputePathToPose">
            <ComputePathToPose goal="{goal}" path="{path}" planner_id="{selected_planner}" error_code_id="{compute_path_error_code}"/>
            <Sequence>
              <WouldAPlannerRecoveryHelp error_code="{compute_path_error_code}"/>
              <ClearEntireCostmap name="ClearGlobalCostmap-Context" service_name="global_costmap/clear_entirely_global_costmap"/>
            </Sequence>
          </RecoveryNode>
        </RateController>
        <RecoveryNode number_of_retries="1" name="FollowPath">
          <FollowPath path="{path}" controller_id="{selected_controller}" error_code_id="{follow_path_error_code}"/>
          <Sequence>
            <WouldAControllerRecoveryHelp error_code="{follow_path_error_code}"/>
            <ClearEntireCostmap name="ClearLocalCostmap-Context" service_name="local_costmap/clear_entirely_local_costmap"/>
          </Sequence>
        </RecoveryNode>
      </PipelineSequence>
      <Sequence>
        <Fallback>
          <WouldAControllerRecoveryHelp error_code="{follow_path_error_code}"/>
          <WouldAPlannerRecoveryHelp error_code="{compute_path_error_code}"/>
        </Fallback>
        <ReactiveFallback name="RecoveryFallback">
          <GoalUpdated/>
          <RoundRobin name="RecoveryActions">
            <Sequence name="ClearingActions">
              <ClearEntireCostmap name="ClearLocalCostmap-Subtree" service_name="local_costmap/clear_entirely_local_costmap"/>
              <ClearEntireCostmap name="ClearGlobalCostmap-Subtree" service_name="global_costmap/clear_entirely_global_costmap"/>
            </Sequence>
            <!-- 0.05 m back-off, reordered ahead of Wait (2026-05-20):
                 the primary "no path near wall" failure is start-in-collision,
                 which a costmap clear can't fix (the wall is static_layer);
                 only a small retreat gains clearance. Operator asked for
                 ~3 cm — set to 5 cm so the open-loop chassis actually
                 overcomes deadband/coast. Reverse is unguarded now that
                 collision_monitor is disabled in the AMCL launch; this
                 assumes a typical park has space behind the chassis. -->
            <BackUp backup_dist="0.05" backup_speed="0.10" error_code_id="{backup_error_code}"/>
            <!-- 2 s — last-resort wait so a moving obstacle can clear. -->
            <Wait wait_duration="2.0"/>
          </RoundRobin>
        </ReactiveFallback>
      </Sequence>
    </RecoveryNode>
  </BehaviorTree>
</root>
